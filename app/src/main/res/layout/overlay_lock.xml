<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:orientation="vertical"
    android:gravity="center"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <TextView
        android:id="@+id/lockTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cocoon Lock"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:letterSpacing="0.05"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:id="@+id/dotsRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="40dp">
        <View android:id="@+id/dot0" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="6dp" android:background="@drawable/dot_empty" />
        <View android:id="@+id/dot1" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="6dp" android:background="@drawable/dot_empty" />
        <View android:id="@+id/dot2" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="6dp" android:background="@drawable/dot_empty" />
        <View android:id="@+id/dot3" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="6dp" android:background="@drawable/dot_empty" />
    </LinearLayout>

    <!-- Row 1: 1 2 3 -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/btn1" style="@style/PinKey" android:text="1"
            android:nextFocusRight="@id/btn2" android:nextFocusDown="@id/btn4" />
        <Button android:id="@+id/btn2" style="@style/PinKey" android:text="2"
            android:nextFocusLeft="@id/btn1" android:nextFocusRight="@id/btn3" android:nextFocusDown="@id/btn5" />
        <Button android:id="@+id/btn3" style="@style/PinKey" android:text="3"
            android:nextFocusLeft="@id/btn2" android:nextFocusDown="@id/btn6" />
    </LinearLayout>

    <!-- Row 2: 4 5 6 -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/btn4" style="@style/PinKey" android:text="4"
            android:nextFocusUp="@id/btn1" android:nextFocusRight="@id/btn5" android:nextFocusDown="@id/btn7" />
        <Button android:id="@+id/btn5" style="@style/PinKey" android:text="5"
            android:nextFocusUp="@id/btn2" android:nextFocusLeft="@id/btn4" android:nextFocusRight="@id/btn6" android:nextFocusDown="@id/btn8" />
        <Button android:id="@+id/btn6" style="@style/PinKey" android:text="6"
            android:nextFocusUp="@id/btn3" android:nextFocusLeft="@id/btn5" android:nextFocusDown="@id/btn9" />
    </LinearLayout>

    <!-- Row 3: 7 8 9 -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/btn7" style="@style/PinKey" android:text="7"
            android:nextFocusUp="@id/btn4" android:nextFocusRight="@id/btn8" android:nextFocusDown="@id/btn0" />
        <Button android:id="@+id/btn8" style="@style/PinKey" android:text="8"
            android:nextFocusUp="@id/btn5" android:nextFocusLeft="@id/btn7" android:nextFocusRight="@id/btn9" android:nextFocusDown="@id/btn0" />
        <Button android:id="@+id/btn9" style="@style/PinKey" android:text="9"
            android:nextFocusUp="@id/btn6" android:nextFocusLeft="@id/btn8" android:nextFocusDown="@id/btnDel" />
    </LinearLayout>

    <!-- Row 4: (blank) 0 Del -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
        <View android:layout_width="64dp" android:layout_height="64dp" android:layout_margin="8dp" />
        <Button android:id="@+id/btn0" style="@style/PinKey" android:text="0"
            android:nextFocusUp="@id/btn7" android:nextFocusRight="@id/btnDel" />
        <Button android:id="@+id/btnDel" style="@style/PinKeySmall" android:text="⌫"
            android:nextFocusUp="@id/btn9" android:nextFocusLeft="@id/btn0" />
    </LinearLayout>

</LinearLayout>
